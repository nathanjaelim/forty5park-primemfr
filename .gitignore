# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# --- Virtualenv / packaging ---
.venv/
venv/
env/
ENV/

# --- uv / lock file ---
# Note: the uv community convention is to COMMIT uv.lock for reproducibility
# (like package-lock.json in npm). Gitignoring it means each `uv sync` may
# resolve to different dependency versions across machines. Comment the
# next line out if your team prefers the committed-lockfile convention.
uv.lock

# --- Tool caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/
.nox/

# --- Editor / OS ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# --- Notebooks / interactive ---
.ipynb_checkpoints/

# --- Node artifacts (used by scripts in outputs/ for pptx generation) ---
node_modules/
package-lock.json
package.json

# --- Project-specific data and artifacts ---------------------------------
# We track ONLY the four source parquets that the pipeline reads as inputs.
# Everything else under artifacts/ is generated and reproducible from those.

# Ignore all parquets by default ...
*.parquet

# ... then explicitly track the source data drops.
!artifacts/042026-hist-rent-12060-12060.parquet
!artifacts/042026-property-enriched-12060.parquet
!artifacts/042026-rent-12060.parquet
!artifacts/042026-unit-mix-enriched-12060.parquet
!artifacts/yardi_sales_atl.parquet

# Generated CV state, scratch, and per-run logs.
artifacts/stacking_scratch/
artifacts/tune_cb_scratch/
artifacts/optuna_journal.log*
artifacts/optuna_study.db*
artifacts/run.log
artifacts/stdout.log
artifacts/test.txt
artifacts/feature_importance.csv

# Generated OOF predictions and segmentation reports — reproducible.
artifacts/oof_predictions*.parquet
artifacts/segment_tables.json
artifacts/error_segmentation_report.md
artifacts/optuna_catboost_study.json
artifacts/optuna_study.json

# Backups.
artifacts/best_*.json.bak
artifacts/optuna_*.json.bak

# Track the tuned hyperparameters (best_params.json, best_catboost_params.json)
# and the metrics*.json for the three model variants — these document the
# production state and the team will want them in the PR.
# (No explicit !rule needed; they're not matched above.)

# EDA: track curated reference data, ignore generated images and parquets.
eda/*.png
eda/*.html
eda/EDA_report.html
# (atlanta_landmarks.csv / .json are reference data — tracked.)

# Pretraining tables (regenerated by build_pretraining_v2.py).
pretraining*.parquet

# --- Local-only deliverables (decks, exports, drafts) ---
# These are shared externally; not part of the trained-model surface area.
*.pptx
*.docx
*.pdf

# --- Secrets ---
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
